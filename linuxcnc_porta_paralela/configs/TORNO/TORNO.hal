#setp parport.0.pin-15-in-not false
#loadusr -Wn btn_shutdown /usr/local/bin/btn_shutdown.sh



# Load Classicladder without GUI (can reload LADDER GUI in AXIS GUI
loadusr classicladder --nogui custom.clp
