# Generated by stepconf 1.1 at Sun Apr 12 08:19:42 2020
# If you make changes to this file, they will be
# overwritten when you run stepconf again
loadrt [KINS]KINEMATICS
loadrt [EMCMOT]EMCMOT base_period_nsec=[EMCMOT]BASE_PERIOD servo_period_nsec=[EMCMOT]SERVO_PERIOD num_joints=[KINS]JOINTS num_dio=10 num_aio=10
loadrt hal_parport cfg="0xdce8 out 0x378 in"
setp parport.0.reset-time 1000
loadrt stepgen step_type=0,0,0
loadrt encoder num_chan=5
loadrt abs count=1
loadrt scale count=6
#loadrt limites count=1
loadrt lowpass count=1
loadrt near
loadrt charge_pump
net estop-out iocontrol.0.user-enable-out
net charge-pump <= charge-pump.out
loadrt pwmgen output_type=1
loadrt classicladder_rt numPhysInputs=60 numPhysOutputs=60 numS32in=10 numS32out=10 numFloatIn=10 numFloatOut=10
loadrt message names=oleo messages="NIVEL LUBRIFICAÇAO BAIXO"



################################spindle abs##############################
loadrt mux2 count=1
loadrt mult2 count=1

addf mux2.0 servo-thread
addf mult2.0 servo-thread

setp mux2.0.in0 1
setp mux2.0.in1 -1
##########################################################################




loadrt carousel pockets=100 dir=1 encoding=index
addf carousel.0 servo-thread




addf parport.0.read base-thread
addf parport.1.read base-thread
addf stepgen.make-pulses base-thread
addf encoder.update-counters base-thread
addf charge-pump base-thread
addf pwmgen.make-pulses base-thread
addf parport.0.write base-thread
addf parport.0.reset base-thread
addf parport.1.write base-thread
addf oleo servo-thread

#addf limites.0 servo-thread

addf scale.1 servo-thread
addf scale.2 servo-thread
addf scale.3 servo-thread
addf scale.4 servo-thread

addf scale.5 servo-thread

addf stepgen.capture-position servo-thread
addf encoder.capture-position servo-thread
addf motion-command-handler servo-thread
addf motion-controller servo-thread
addf classicladder.0.refresh servo-thread
addf stepgen.update-freq servo-thread
addf pwmgen.update servo-thread
addf abs.0 servo-thread
addf scale.0 servo-thread
addf lowpass.0 servo-thread
addf near.0 servo-thread

##########################GAMA###################################

net gama-ladder scale.2.gain => classicladder.0.floatout-02
net spindle-cmd-rpm scale.2.in
net gama2 scale.2.out => scale.3.in

setp scale.3.gain 0.01
net SPN-VEL-SCAL pwmgen.0.value => scale.3.out

#net gama-baixa parport.0.pin-06-out classicladder.0.out-36
#net gama-alta parport.0.pin-07-out classicladder.0.out-35

#net spindle-brake   => parport.0.pin-08-out => classicladder.0.in-35


#################################################################


net spindle-on <= spindle.0.on => pwmgen.0.enable
net spindle-pwm <= pwmgen.0.pwm
setp pwmgen.0.pwm-freq 15000.0


###########################ajuste RPM aqui##################
#setp pwmgen.0.scale 5128, 2895 foi o ajuste para acertar o rpm pela nossa config de alavanca e inversor
#setp pwmgen.0.scale 2895 - novo teste de 4810
#setp pwmgen.0.scale 4810 aqui variou pouco, em torno de 5% somente em RPM alto
setp pwmgen.0.scale 4560
#############################################################



setp pwmgen.0.offset 0.0
setp pwmgen.0.dither-pwm true
net spindle-cmd-rpm     <= spindle.0.speed-out
net spindle-cmd-rpm-abs <= spindle.0.speed-out-abs
net spindle-cmd-rps     <= spindle.0.speed-out-rps
net spindle-cmd-rps-abs <= spindle.0.speed-out-rps-abs
net spindle-at-speed    => spindle.0.at-speed


###############################spindle reverse############################
net spindle-ccw <= spindle.0.reverse => mux2.0.sel
net spindle-rev-mult <= mux2.0.out => mult2.0.in0
##########################################################################

net coolant-flood <= iocontrol.0.coolant-flood

setp encoder.0.position-scale 100.000000
setp encoder.0.counter-mode 1


###############################spindle reverse############################
net spindle-position encoder.0.position => mult2.0.in1
net spindle-position-sig => mult2.0.out => spindle.0.revs
##########################################################################

net spindle-velocity-feedback-rps encoder.0.velocity => spindle.0.speed-in
net spindle-index-enable encoder.0.index-enable <=> spindle.0.index-enable
net spindle-phase-a encoder.0.phase-A
net spindle-phase-b encoder.0.phase-B
net spindle-index encoder.0.phase-Z

net spindle-pwm     => parport.0.pin-01-out

net xstep           => parport.0.pin-02-out
setp parport.0.pin-02-out-reset 1
net xdir            => parport.0.pin-03-out
setp parport.0.pin-03-out-invert 1

net zstep           => parport.0.pin-04-out
setp parport.0.pin-04-out-reset 1
net zdir            => parport.0.pin-05-out
setp parport.0.pin-05-out-invert 1

net cstep           => parport.0.pin-06-out
setp parport.0.pin-06-out-reset 1
net cdir            => parport.0.pin-07-out
setp parport.0.pin-07-out-invert 1




net charge-pump     => parport.0.pin-14-out

net spindle-on      => parport.1.pin-01-out
net spindle-ccw     => parport.1.pin-14-out
#setp parport.1.pin-14-out-invert 1
#net spindle-brake <= spindle.0.brake

net coolant-flood   => parport.1.pin-17-out


#PINOS ENCODER
net all-home        <= parport.1.pin-03-in-not
net spindle-phase-a <= parport.1.pin-11-in-not
#net spindle-phase-b <= parport.1.pin-15-in-not
net spindle-index   <= parport.1.pin-13-in-not

#EU QUE FIZ, TESTE
#net spindle-phase-a => joint.3.encoder.phase-A
#net spindle-phase-b => joint.3.encoder.phase-B
#net spindle-index => joint.3.encoder.index
#setp joint.3.encoder.input-index-enable 1
#net spindle-encoder-pos-raw => joint.3.position-fb
#net spindle-encoder-vel-raw => joint.3.velocity-fb


setp stepgen.0.position-scale [JOINT_0]SCALE
setp stepgen.0.steplen 1
setp stepgen.0.stepspace 0
setp stepgen.0.dirhold 35000
setp stepgen.0.dirsetup 35000
setp stepgen.0.maxaccel [JOINT_0]STEPGEN_MAXACCEL
net xpos-cmd joint.0.motor-pos-cmd => stepgen.0.position-cmd
net xpos-fb stepgen.0.position-fb => joint.0.motor-pos-fb
net xstep <= stepgen.0.step
net xdir <= stepgen.0.dir
net xenable joint.0.amp-enable-out => stepgen.0.enable => charge-pump.enable
net all-home => joint.0.home-sw-in

setp stepgen.1.position-scale [JOINT_1]SCALE
setp stepgen.1.steplen 1
setp stepgen.1.stepspace 0
setp stepgen.1.dirhold 35000
setp stepgen.1.dirsetup 35000
setp stepgen.1.maxaccel [JOINT_1]STEPGEN_MAXACCEL
net zpos-cmd joint.1.motor-pos-cmd => stepgen.1.position-cmd
net zpos-fb stepgen.1.position-fb => joint.1.motor-pos-fb
net zstep <= stepgen.1.step
net zdir <= stepgen.1.dir
net zenable joint.1.amp-enable-out => stepgen.1.enable
net all-home => joint.1.home-sw-in


setp stepgen.2.position-scale [JOINT_2]SCALE
setp stepgen.2.steplen 1
setp stepgen.2.stepspace 0
setp stepgen.2.dirhold 35000
setp stepgen.2.dirsetup 35000
setp stepgen.2.maxaccel [JOINT_2]STEPGEN_MAXACCEL
net cpos-cmd joint.2.motor-pos-cmd => stepgen.2.position-cmd
net cpos-fb stepgen.2.position-fb => joint.2.motor-pos-fb
net cstep <= stepgen.2.step
net cdir <= stepgen.2.dir
net cenable joint.2.amp-enable-out => stepgen.2.enable
#net all-home => joint.2.home-sw-in



net estop-out <= iocontrol.0.user-enable-out
net estop-ext => iocontrol.0.emc-enable-in


#loadusr -W hal_manualtoolchange
net tool-change-loopback iocontrol.0.tool-change => iocontrol.0.tool-changed
#net tool-change iocontrol.0.tool-change => hal_manualtoolchange.change
#net tool-changed iocontrol.0.tool-changed <= hal_manualtoolchange.changed
#net tool-number iocontrol.0.tool-prep-number => hal_manualtoolchange.number
net tool-prepare-loopback iocontrol.0.tool-prepare => iocontrol.0.tool-prepared


