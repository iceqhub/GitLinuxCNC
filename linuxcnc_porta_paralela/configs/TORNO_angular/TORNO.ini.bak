# Generated by stepconf 1.1 at Sun Apr 12 08:19:42 2020
# If you make changes to this file, they will be
# overwritten when you run stepconf again

[EMC]
MACHINE = TORNO
DEBUG = 0
VERSION = 1.1

[DISPLAY]
DISPLAY = axis
EDITOR = mousepad
TOOL_EDITOR = tooledit x z diam front back orien
POSITION_OFFSET = RELATIVE
POSITION_FEEDBACK = ACTUAL
ARCDIVISION = 64
GRIDS = 10mm 20mm 50mm 100mm 1in 2in 5in 10in
MAX_FEED_OVERRIDE = 1.2
MIN_SPINDLE_OVERRIDE = 0.0
MAX_SPINDLE_OVERRIDE = 1.2
DEFAULT_LINEAR_VELOCITY = 5.00
MIN_LINEAR_VELOCITY = 0
MAX_LINEAR_VELOCITY = 100
DEFAULT_ANGULAR_VELOCITY = 36.00
MIN_ANGULAR_VELOCITY = 0
MAX_ANGULAR_VELOCITY = 360.00
INTRO_GRAPHIC = linuxcnc.gif
INTRO_TIME = 5
PROGRAM_PREFIX = /home/cnc/linuxcnc/nc_files
INCREMENTS = 5mm 1mm .5mm .1mm .05mm .01mm .005mm
PYVCP = custompanel.xml
LATHE = 1
OPEN_FILE =/home/cnc/linuxcnc/nc_files/ini.ngc



###############################################################################################
####################################copie daqui################################################ 
###############################################################################################

TKPKG             = Ngcgui 1.0

# for startup NGCGUI_PREAMBLE, NGCGUI_SUBFILE, NGCGUI_POSTAMBLE, TTT_PREAMBLE
# items, specifly:
#   a) absolute filename (start with /)
#   b) relative filename: search directories specified by
#      [DISPLAY]PROGRAM_PREFIX and [RS274NGC]SUBROUTINE_PATH

NGCGUI_PREAMBLE   = .ngcgui_start.ngc
NGCGUI_SUBFILE    = .facear.ngc
NGCGUI_SUBFILE    = .externo.ngc
NGCGUI_SUBFILE    = .interno.ngc
NGCGUI_SUBFILE    = .furacao.ngc
NGCGUI_SUBFILE    = .rosca.ngc
NGCGUI_SUBFILE    = .canal_diam.ngc
NGCGUI_SUBFILE    = .canal_face.ngc
NGCGUI_SUBFILE    = .canto.ngc
NGCGUI_SUBFILE    = .sangrar.ngc
NGCGUI_SUBFILE    = .perfil.ngc
NGCGUI_POSTAMBLE   = .ngcgui_FIN.ngc
NGCGUI_FONT       = Helvetica -9 normal
NGCGUI_OPTIONS    = nonew noremove

#NGCGUI_OPTIONS   = opt1 opt2 ...
# opt items:
#   nonew      -- disallow making   new tab page
#   noremove   -- disallow removing any tab page
#   noauto     -- no autosend (makeFile, then manually send)
#   noiframe   -- no internal image, image  on separate toplevel
#   nom2       -- no m2 terminator (use %)

###############################################################################################
####################################ate aqui################################################### 
###############################################################################################





[KINS]
JOINTS = 3
KINEMATICS = trivkins coordinates=XZC

[FILTER]
PROGRAM_EXTENSION = .png,.gif,.jpg Greyscale Depth Image
PROGRAM_EXTENSION = .py Python Script
PROGRAM_EXTENSION = .txt,.nc,.tap G-Code File
png = image-to-gcode
gif = image-to-gcode
jpg = image-to-gcode
py = python

[TASK]
TASK = milltask
CYCLE_TIME = 0.010


[PYTHON]
PATH_PREPEND=./python
PATH_APPEND=./python/remap_lib/python-stdglue
TOPLEVEL=python/toplevel.py
LOG_LEVEL = 0


[RS274NGC]
PARAMETER_FILE = linuxcnc.var
RS274NGC_STARTUP_CODE = o<.startup>call
FEATURES = 12 
REMAP = M6 modalgroup=6 ngc=.m6
REMAP = M400 modalgroup=10 py=m400


[EMCMOT]
EMCMOT = motmod
COMM_TIMEOUT = 1.0
BASE_PERIOD =28000
SERVO_PERIOD =1000000

[HAL]
HALUI = halui
HALFILE = TORNO.hal
HALFILE = custom.hal
POSTGUI_HALFILE = custom_postgui.hal
#POSTGUI_HALFILE = postgui_call_list.hal

[HALUI]
# MDI commands
MDI_COMMAND = T01M6G43
MDI_COMMAND = T02M6G43
MDI_COMMAND = T03M6G43
MDI_COMMAND = T04M6G43
MDI_COMMAND = T05M6G43
MDI_COMMAND = T06M6G43
MDI_COMMAND = T07M6G43
MDI_COMMAND = T08M6G43
MDI_COMMAND = T09M6G43
MDI_COMMAND = T10M6G43
MDI_COMMAND = T11M6G43
MDI_COMMAND = T12M6G43
MDI_COMMAND = T13M6G43
MDI_COMMAND = T14M6G43
MDI_COMMAND = T15M6G43
MDI_COMMAND = o<.m3>call
MDI_COMMAND = o<.m4>call
MDI_COMMAND = M5
MDI_COMMAND = o<.seta_x>call
MDI_COMMAND = o<.seta_xneg>call
MDI_COMMAND = o<.seta_z>call
MDI_COMMAND = o<.restaura>call
MDI_COMMAND = G97 S#<_hal[pyvcp.rpm]>
MDI_COMMAND = o<.seta_z_neg>call
MDI_COMMAND = o<.abort>call
MDI_COMMAND = o<.ativa>call
MDI_COMMAND = o<.desativa>call
MDI_COMMAND = M64P6
MDI_COMMAND = M64P7
MDI_COMMAND = M64P8

[TRAJ]
COORDINATES =  X Z C
LINEAR_UNITS = mm
ANGULAR_UNITS = degree
DEFAULT_LINEAR_VELOCITY = 15
MAX_VELOCITY = 100
POSITION_FILE = position.txt
NO_FORCE_HOMING = 1


[EMCIO]
EMCIO = io
CYCLE_TIME = 0.100
TOOL_TABLE = tool.tbl
TOOL_CHANGE_WITH_SPINDLE_ON = 1


[AXIS_X]
#MAX_VELOCITY = 66.6666667 padrao eneias, MAX VELO DE 25 FICOU BOA APARENTEMENTE
MAX_VELOCITY = 20
MAX_ACCELERATION = 100.0
#MAX_ACCELERATION = 400.0
#MIN_LIMIT = -210.001
MIN_LIMIT = -180.001
#MIN_LIMIT = -375.001
MAX_LIMIT = 0.001

[JOINT_0]
TYPE = LINEAR
HOME = 0.0
MIN_LIMIT = -180.001
